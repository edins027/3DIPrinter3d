<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Catálogo Premium</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<style>
body{
font-family:'Inter';
background:#0f172a;
color:white;
padding:20px;
}

/* HEADER */
.header{text-align:center;margin-bottom:20px;}
.logo{width:90px;}

/* GRID */
.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(160px,1fr));
gap:15px;
}

.card{
background:#1e293b;
padding:15px;
border-radius:16px;
text-align:center;
transition:.3s;
}

.card:hover{transform:scale(1.03);}

.card img{width:100%;border-radius:10px;}

.btn{
background:#22c55e;
padding:10px;
border:none;
width:100%;
border-radius:10px;
margin-top:8px;
cursor:pointer;
}

/* MODAL */
.modal{
position:fixed;
top:0;left:0;
width:100%;height:100%;
background:rgba(0,0,0,0.8);
display:none;
align-items:center;
justify-content:center;
}

.modal-content{
background:#1e293b;
padding:20px;
border-radius:20px;
width:90%;
max-width:400px;
text-align:center;
}

.modal img{
width:100%;
border-radius:10px;
margin-bottom:10px;
}

/* CARRINHO */
.cart-box{
position:fixed;
bottom:10px;
right:10px;
background:#1e293b;
padding:15px;
border-radius:16px;
width:260px;
}

.item{font-size:13px;margin:5px 0;}

</style>
</head>

<body>

<div class="header">
<img src="logo.png" class="logo">
<h2>Catálogo</h2>
</div>

<div class="grid" id="produtos"></div>

<div class="cart-box" id="cart"></div>

<div class="modal" id="modal">
<div class="modal-content" id="modalContent"></div>
</div>

<script>

const PLANILHA = "COLE_LINK_CSV"
const WHATSAPP = "5511999999999"

let produtos = []
let carrinho = {}

async function carregar(){
const res = await fetch(PLANILHA)
const txt = await res.text()

const linhas = txt.split("\n").slice(1)

linhas.forEach(l=>{
const [nome, preco, categoria, imagens, tempo] = l.split(",")

produtos.push({
nome,
preco: parseFloat(preco),
categoria,
imagens: imagens.split(";"),
tempo
})
})

render()
}

function render(){
const grid = document.getElementById("produtos")
grid.innerHTML = ""

produtos.forEach((p,i)=>{
grid.innerHTML += `
<div class="card">
<img src="images/${p.imagens[0]}">
<h3>${p.nome}</h3>
<p>R$ ${p.preco}</p>
<button class="btn" onclick="detalhes(${i})">Ver detalhes</button>
<button class="btn" onclick="add(${i})">Adicionar</button>
</div>`
})
}

function detalhes(i){
const p = produtos[i]

let imgs = ""
p.imagens.forEach(img=>{
imgs += `<img src="images/${img}">`
})

document.getElementById("modalContent").innerHTML = `
<h3>${p.nome}</h3>
${imgs}
<p>R$ ${p.preco}</p>
<p>${p.tempo}</p>
<button class="btn" onclick="add(${i})">Adicionar</button>
<button class="btn" onclick="fechar()">Fechar</button>
`

document.getElementById("modal").style.display = "flex"
}

function fechar(){
document.getElementById("modal").style.display = "none"
}

function add(i){
if(!carrinho[i]){
carrinho[i] = { ...produtos[i], qtd:1 }
}else{
carrinho[i].qtd++
}
renderCart()
}

function remover(i){
delete carrinho[i]
renderCart()
}

function renderCart(){
const c = document.getElementById("cart")
c.innerHTML = "<h3>Carrinho</h3>"

let total = 0

Object.entries(carrinho).forEach(([i,item])=>{
total += item.preco * item.qtd

c.innerHTML += `
<div class="item">
${item.nome} x${item.qtd}
<button onclick="add(${i})">+</button>
<button onclick="remover(${i})">x</button>
</div>`
})

c.innerHTML += `<p>Total: R$ ${total}</p>
<button class="btn" onclick="finalizar()">Finalizar</button>`
}

function finalizar(){
let msg = "Pedido:%0A"
let total = 0

Object.values(carrinho).forEach(i=>{
msg += `- ${i.nome} x${i.qtd}%0A`
total += i.preco * i.qtd
})

msg += `%0ATotal: R$ ${total}`

window.open(`https://wa.me/${WHATSAPP}?text=${msg}`)
}

carregar()

</script>

</body>
</html>
